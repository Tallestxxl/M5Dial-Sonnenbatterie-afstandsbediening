#!/usr/bin/env python3
"""Local sonnenBatterie mock server for safe M5 Dial Wi-Fi/HTTP bring-up."""

from __future__ import annotations

import argparse
from dataclasses import dataclass, field
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
import json
import time
from typing import Any
from urllib.parse import urlparse


@dataclass
class MockState:
    allow_writes: bool = False
    soc: int = 67
    production_w: int = 1400
    consumption_w: int = 620
    grid_w: int = -300
    battery_w: int = 180
    mode: str = "MOCK"
    request_log: list[tuple[str, str, str]] = field(default_factory=list)

    def status_payload(self) -> dict[str, Any]:
        tick = int(time.monotonic()) % 20
        soc = max(5, min(100, self.soc + tick // 4))
        production = self.production_w + tick * 17
        consumption = self.consumption_w + tick * 9
        grid = self.grid_w + tick * 3
        battery = self.battery_w - tick * 4
        return {
            "RSOC": soc,
            "Production_W": production,
            "Consumption_W": consumption,
            "GridFeedIn_W": grid,
            "Pac_total_W": battery,
            "OperatingMode": self.mode,
            "Timestamp": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        }


class SonnenMockHandler(BaseHTTPRequestHandler):
    server_version = "SonnenMock/0.1"

    @property
    def state(self) -> MockState:
        return self.server.state  # type: ignore[attr-defined]

    def log_message(self, fmt: str, *args: Any) -> None:
        print("%s - %s" % (self.address_string(), fmt % args))

    def write_json(self, status: int, payload: dict[str, Any]) -> None:
        data = json.dumps(payload, sort_keys=True).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def read_body(self) -> str:
        length = int(self.headers.get("Content-Length", "0"))
        if length <= 0:
            return ""
        return self.rfile.read(length).decode("utf-8", errors="replace")

    def do_GET(self) -> None:
        status, payload = handle_mock_request(self.state, "GET", self.path, "")
        self.write_json(status, payload)

    def do_PUT(self) -> None:
        self.handle_write()

    def do_POST(self) -> None:
        self.handle_write()

    def do_PATCH(self) -> None:
        self.handle_write()

    def handle_write(self) -> None:
        body = self.read_body()
        status, payload = handle_mock_request(self.state, self.command, self.path, body)
        self.write_json(status, payload)


def handle_mock_request(state: MockState, method: str, raw_path: str, body: str) -> tuple[int, dict[str, Any]]:
    path = urlparse(raw_path).path
    method = method.upper()
    state.request_log.append((method, path, body))

    if method == "GET" and path == "/api/v2/status":
        return 200, state.status_payload()
    if method == "GET":
        return 404, {"error": "not_found", "path": path}

    if method not in {"POST", "PUT", "PATCH"}:
        return 405, {"error": "method_not_allowed", "path": path}
    if not state.allow_writes:
        return 423, {"error": "writes_locked", "path": path}
    if path == "/api/v2/configurations":
        return 200, {"ok": True, "path": path, "body": body}
    if path.startswith("/api/v2/setpoint/charge/") or path.startswith("/api/v2/setpoint/discharge/"):
        return 200, {"ok": True, "path": path, "body": body}
    return 404, {"error": "not_found", "path": path}


def make_server(host: str, port: int, state: MockState) -> ThreadingHTTPServer:
    server = ThreadingHTTPServer((host, port), SonnenMockHandler)
    server.state = state  # type: ignore[attr-defined]
    return server


def make_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--host", default="0.0.0.0")
    parser.add_argument("--port", type=int, default=8766)
    parser.add_argument("--allow-writes", action="store_true")
    parser.add_argument("--soc", type=int, default=67)
    parser.add_argument("--production-w", type=int, default=1400)
    parser.add_argument("--consumption-w", type=int, default=620)
    parser.add_argument("--grid-w", type=int, default=-300)
    parser.add_argument("--battery-w", type=int, default=180)
    return parser


def main(argv: list[str] | None = None) -> int:
    args = make_parser().parse_args(argv)
    state = MockState(
        allow_writes=args.allow_writes,
        soc=args.soc,
        production_w=args.production_w,
        consumption_w=args.consumption_w,
        grid_w=args.grid_w,
        battery_w=args.battery_w,
    )
    server = make_server(args.host, args.port, state)
    mode = "writes enabled" if args.allow_writes else "writes locked"
    print(f"Sonnen mock listening on http://{args.host}:{args.port} ({mode})")
    print("Status endpoint: /api/v2/status")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopping Sonnen mock")
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
