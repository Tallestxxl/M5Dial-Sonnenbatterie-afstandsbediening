#!/usr/bin/env python3
"""Small, dependency-free probe for a local sonnenBatterie API."""

from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys
import urllib.error
import urllib.parse
import urllib.request
from typing import Any


FIELD_GROUPS = {
    "soc": ("USOC", "RSOC", "RelativeStateOfCharge"),
    "production_w": ("Production_W", "ProductionW", "PV_Production_W"),
    "consumption_w": ("Consumption_W", "Consumption_Avg", "ConsumptionW"),
    "grid_w": ("GridFeedIn_W", "GridFeedIn", "GridFeedInW"),
    "battery_w": ("Pac_total_W", "BatteryPower_W", "Battery_W"),
    "mode": ("OperatingMode", "EM_OperatingMode", "Mode"),
    "timestamp": ("Timestamp", "System_Time", "timestamp"),
}

DEFAULT_CONFIG_PATH = Path("arduino/sketchbook/SonnenDialRemote/sonnen_config.h")


def cpp_string(value: str) -> str:
    return '"' + value.replace("\\", "\\\\").replace('"', '\\"') + '"'


def cpp_json_string(value: str) -> str:
    return cpp_string(value)


def render_config(args: argparse.Namespace) -> str:
    return f"""#pragma once

// Generated by scripts/sonnen-probe make-config.
// Keep this file private; it can contain Wi-Fi credentials and API tokens.

static const char WIFI_SSID[] = {cpp_string(args.wifi_ssid)};
static const char WIFI_PASSWORD[] = {cpp_string(args.wifi_password)};

static const char SONNEN_HOST[] = {cpp_string(args.host)};
static const uint16_t SONNEN_PORT = {args.port};
static const char SONNEN_AUTH_HEADER[] = {cpp_string(args.auth_header)};
static const char SONNEN_AUTH_TOKEN[] = {cpp_string(args.token)};

#define SONNEN_DEMO_MODE {1 if args.demo else 0}

#define SONNEN_STATUS_PATH {cpp_string(args.status_path)}
#define SONNEN_CONFIGURATION_PATH {cpp_string(args.configuration_path)}
#define SONNEN_CHARGE_SETPOINT_PATH {cpp_string(args.charge_path)}
#define SONNEN_DISCHARGE_SETPOINT_PATH {cpp_string(args.discharge_path)}

#define SONNEN_ALLOW_WRITES {1 if args.allow_writes else 0}
#define SONNEN_CONFIG_METHOD {cpp_string(args.config_method)}
#define SONNEN_SETPOINT_METHOD {cpp_string(args.setpoint_method)}
#define SONNEN_SELF_CONSUMPTION_BODY {cpp_json_string(args.self_consumption_body)}
#define SONNEN_MANUAL_MODE_BODY {cpp_json_string(args.manual_mode_body)}
#define SONNEN_SETPOINT_BODY {cpp_json_string(args.setpoint_body)}
#define SONNEN_ENABLE_MANUAL_BEFORE_SETPOINT {1 if args.enable_manual_before_setpoint else 0}

#define SONNEN_DEFAULT_SETPOINT_W {args.default_setpoint_w}
#define SONNEN_MAX_SETPOINT_W {args.max_setpoint_w}
#define SONNEN_SETPOINT_STEP_W {args.setpoint_step_w}

#define SONNEN_WIFI_TIMEOUT_MS {args.wifi_timeout_ms}
#define SONNEN_HTTP_TIMEOUT_MS {args.http_timeout_ms}
#define SONNEN_WIFI_OFF_AFTER_REQUEST {1 if args.wifi_off_after_request else 0}
#define SONNEN_STATUS_REFRESH_MS {args.status_refresh_ms}
#define SONNEN_ACTIVE_REFRESH_MS {args.active_refresh_ms}
#define SONNEN_IDLE_REFRESH_MS {args.idle_refresh_ms}
#define SONNEN_ERROR_REFRESH_MS {args.error_refresh_ms}
#define SONNEN_ACTIVE_POWER_THRESHOLD_W {args.active_power_threshold_w}
#define SONNEN_DIM_AFTER_MS {args.dim_after_ms}
#define SONNEN_SLEEP_AFTER_MS {args.sleep_after_ms}
#define SONNEN_ENABLE_POWER_OFF {1 if args.enable_power_off else 0}
#define SONNEN_ACTIVE_BRIGHTNESS {args.active_brightness}
#define SONNEN_DIM_BRIGHTNESS {args.dim_brightness}
"""


def build_base_url(host: str, port: int) -> str:
    if "://" not in host:
        host = f"http://{host}"

    parsed = urllib.parse.urlsplit(host)
    if parsed.port is None and port != 80:
        netloc = f"{parsed.hostname}:{port}"
        if parsed.username:
            auth = parsed.username
            if parsed.password:
                auth += f":{parsed.password}"
            netloc = f"{auth}@{netloc}"
        parsed = parsed._replace(netloc=netloc)

    return urllib.parse.urlunsplit(parsed).rstrip("/")


def build_url(host: str, port: int, path: str) -> str:
    if not path.startswith("/"):
        path = f"/{path}"
    return f"{build_base_url(host, port)}{path}"


def request(
    *,
    method: str,
    url: str,
    auth_header: str,
    token: str,
    body: str,
    timeout: float,
) -> tuple[int, str]:
    data = body.encode("utf-8") if body else None
    req = urllib.request.Request(url, data=data, method=method.upper())
    if token:
        req.add_header(auth_header, token)
    if data is not None:
        req.add_header("Content-Type", "application/json")

    try:
        with urllib.request.urlopen(req, timeout=timeout) as response:
            return response.status, response.read().decode("utf-8", errors="replace")
    except urllib.error.HTTPError as exc:
        payload = exc.read().decode("utf-8", errors="replace")
        return exc.code, payload


def find_first(payload: dict[str, Any], keys: tuple[str, ...]) -> Any:
    for key in keys:
        if key in payload:
            return payload[key]
    return None


def summarize_status(text: str) -> int:
    try:
        payload = json.loads(text)
    except json.JSONDecodeError as exc:
        print(f"Response is not valid JSON: {exc}", file=sys.stderr)
        print(text[:1000])
        return 2

    if not isinstance(payload, dict):
        print("Response JSON is not an object.", file=sys.stderr)
        print(json.dumps(payload, indent=2, sort_keys=True)[:1000])
        return 2

    found_any = False
    for label, keys in FIELD_GROUPS.items():
        value = find_first(payload, keys)
        if value is None:
            continue
        found_any = True
        print(f"{label}: {value}")

    if not found_any:
        print("No known Sonnen status fields found. Raw top-level keys:")
        for key in sorted(payload.keys()):
            print(f"- {key}")
        return 1

    return 0


def add_common_args(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--host", required=True, help="Sonnen host/IP, with optional http:// prefix")
    parser.add_argument("--port", type=int, default=80)
    parser.add_argument("--token", default="", help="Local API token, if required")
    parser.add_argument("--auth-header", default="Auth-Token")
    parser.add_argument("--timeout", type=float, default=5.0)


def make_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    subparsers = parser.add_subparsers(dest="command", required=True)

    status = subparsers.add_parser("status", help="Read and summarize status JSON")
    add_common_args(status)
    status.add_argument("--path", default="/api/v2/status")
    status.add_argument("--raw", action="store_true", help="Print raw JSON after the summary")

    request_parser = subparsers.add_parser("request", help="Send a custom request")
    add_common_args(request_parser)
    request_parser.add_argument("--path", required=True)
    request_parser.add_argument("--method", default="GET", choices=("GET", "POST", "PUT", "PATCH"))
    request_parser.add_argument("--body", default="")
    request_parser.add_argument("--allow-write", action="store_true")
    request_parser.add_argument("--confirm-write", default="")

    config = subparsers.add_parser("make-config", help="Generate private firmware sonnen_config.h")
    config.add_argument("--output", default=str(DEFAULT_CONFIG_PATH))
    config.add_argument("--force", action="store_true", help="Overwrite an existing output file")
    config.add_argument("--wifi-ssid", required=True)
    config.add_argument("--wifi-password", required=True)
    config.add_argument("--host", required=True, help="Sonnen host/IP, without path")
    config.add_argument("--port", type=int, default=80)
    config.add_argument("--token", default="")
    config.add_argument("--auth-header", default="Auth-Token")
    config.add_argument("--demo", action="store_true", help="Generate config with SONNEN_DEMO_MODE=1")
    config.add_argument("--status-path", default="/api/v2/status")
    config.add_argument("--configuration-path", default="/api/v2/configurations")
    config.add_argument("--charge-path", default="/api/v2/setpoint/charge")
    config.add_argument("--discharge-path", default="/api/v2/setpoint/discharge")
    config.add_argument("--allow-writes", action="store_true")
    config.add_argument("--config-method", default="PUT")
    config.add_argument("--setpoint-method", default="POST")
    config.add_argument("--self-consumption-body", default='{"EM_OperatingMode":"2"}')
    config.add_argument("--manual-mode-body", default='{"EM_OperatingMode":"1"}')
    config.add_argument("--setpoint-body", default="")
    config.add_argument("--enable-manual-before-setpoint", action=argparse.BooleanOptionalAction, default=True)
    config.add_argument("--default-setpoint-w", type=int, default=500)
    config.add_argument("--max-setpoint-w", type=int, default=3600)
    config.add_argument("--setpoint-step-w", type=int, default=100)
    config.add_argument("--wifi-timeout-ms", type=int, default=9000)
    config.add_argument("--http-timeout-ms", type=int, default=4500)
    config.add_argument("--wifi-off-after-request", action=argparse.BooleanOptionalAction, default=True)
    config.add_argument("--status-refresh-ms", type=int, default=15000)
    config.add_argument("--active-refresh-ms", type=int, default=10000)
    config.add_argument("--idle-refresh-ms", type=int, default=60000)
    config.add_argument("--error-refresh-ms", type=int, default=20000)
    config.add_argument("--active-power-threshold-w", type=int, default=100)
    config.add_argument("--dim-after-ms", type=int, default=20000)
    config.add_argument("--sleep-after-ms", type=int, default=70000)
    config.add_argument("--enable-power-off", action=argparse.BooleanOptionalAction, default=False)
    config.add_argument("--active-brightness", type=int, default=96)
    config.add_argument("--dim-brightness", type=int, default=18)

    return parser


def run_status(args: argparse.Namespace) -> int:
    url = build_url(args.host, args.port, args.path)
    code, text = request(
        method="GET",
        url=url,
        auth_header=args.auth_header,
        token=args.token,
        body="",
        timeout=args.timeout,
    )
    print(f"GET {url}")
    print(f"HTTP {code}")
    if not 200 <= code < 300:
        print(text[:1000])
        return 1

    exit_code = summarize_status(text)
    if args.raw:
        print()
        print(text)
    return exit_code


def run_request(args: argparse.Namespace) -> int:
    method = args.method.upper()
    if method != "GET" and (not args.allow_write or args.confirm_write != "YES"):
        print(
            "Refusing non-GET request. Add --allow-write --confirm-write YES "
            "only after checking the endpoint against your Sonnen model.",
            file=sys.stderr,
        )
        return 2

    url = build_url(args.host, args.port, args.path)
    code, text = request(
        method=method,
        url=url,
        auth_header=args.auth_header,
        token=args.token,
        body=args.body,
        timeout=args.timeout,
    )
    print(f"{method} {url}")
    print(f"HTTP {code}")
    print(text[:4000])
    return 0 if 200 <= code < 300 else 1


def run_make_config(args: argparse.Namespace) -> int:
    output = Path(args.output)
    if output.exists() and not args.force:
        print(f"Refusing to overwrite existing file: {output}", file=sys.stderr)
        print("Use --force after checking the existing config.", file=sys.stderr)
        return 2

    output.parent.mkdir(parents=True, exist_ok=True)
    output.write_text(render_config(args), encoding="utf-8")
    print(f"Wrote {output}")
    if args.allow_writes:
        print("Warning: generated config enables Sonnen writes.", file=sys.stderr)
    else:
        print("Writes remain disabled: SONNEN_ALLOW_WRITES=0")
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = make_parser()
    args = parser.parse_args(argv)
    if args.command == "status":
        return run_status(args)
    if args.command == "request":
        return run_request(args)
    if args.command == "make-config":
        return run_make_config(args)
    parser.error("unknown command")
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
